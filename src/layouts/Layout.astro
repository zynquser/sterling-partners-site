---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ALSA Law — Trusted Legal Counsel · Abu Dhabi & London",
  description = "ALSA Law provides senior-level legal counsel in corporate, litigation, real estate, and family & estate matters.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="bg-white text-navy-900">
    <Nav />
    <main><slot /></main>
    <Footer />

    <!-- Persistent corner mark — always visible, scrolls to top on click -->
    <a
      href="#top"
      aria-label="ALSA Law — back to top"
      class="corner-mark fixed bottom-5 right-5 md:bottom-6 md:right-6 z-40 inline-flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-full bg-navy-900/80 backdrop-blur-md border border-gold-400/40 shadow-lg shadow-navy-950/40 hover:bg-navy-900 hover:border-gold-400 transition-colors group"
    >
      <img
        src="/logo-mark.png"
        alt=""
        width="56"
        height="56"
        class="w-7 h-7 md:w-8 md:h-8 object-contain opacity-90 group-hover:opacity-100 transition-opacity"
      />
    </a>

    <style>
      .corner-mark {
        opacity: 0;
        animation: cornerMarkIn 0.8s ease-out 2.6s forwards;
      }
      @keyframes cornerMarkIn {
        to { opacity: 1; }
      }
      @media (prefers-reduced-motion: reduce) {
        .corner-mark { opacity: 1; animation: none; }
      }
    </style>
  </body>
</html>
