---
---
<section id="about" class="py-24 md:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">

    <!-- ░░ Left panel: Abu Dhabi skyline photo with warm gold duotone ░░ -->
    <div class="lg:col-span-5 order-2 lg:order-1">
      <div class="relative">
        <!-- corner accents -->
        <div class="absolute -top-4 -left-4 w-24 h-24 border-2 border-gold-400 z-10 pointer-events-none"></div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border-2 border-gold-400 z-10 pointer-events-none"></div>

        <div class="relative overflow-hidden" style="aspect-ratio: 4/5;">
          <!-- Photo: Abu Dhabi / UAE corporate skyline -->
          <img
            src="/abu-dhabi.jpg"
            alt="Abu Dhabi skyline"
            class="w-full h-full object-cover object-left"
            loading="lazy"
          />
          <!-- Light overlay — same treatment as the London banner -->
          <div class="absolute inset-0 bg-navy-950/45"></div>
          <!-- Extra darken at bottom for quote readability -->
          <div class="absolute inset-0 bg-gradient-to-t from-navy-950/80 via-transparent to-transparent"></div>
          <!-- Thin gold diagonal accent -->
          <svg class="absolute inset-0 w-full h-full pointer-events-none" preserveAspectRatio="none">
            <line x1="0" y1="0" x2="100%" y2="100%" stroke="rgba(185,145,109,0.3)" stroke-width="1"/>
          </svg>
          <!-- Quote overlay -->
          <div class="absolute bottom-0 left-0 right-0 p-8 lg:p-10">
            <blockquote class="font-serif text-white text-lg lg:text-xl leading-snug">
              "We measure success not by the size of the matter, but by whether the client would entrust us with the next one."
            </blockquote>
            <div class="mt-5 pt-4 border-t border-white/20">
              <div class="text-white/90 text-sm font-medium">Satinder Hunjan KC</div>
              <div class="text-white/55 text-xs tracking-wide mt-0.5">Co-Founder and Chairman</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ░░ Right: text content ░░ -->
    <div class="lg:col-span-7 order-1 lg:order-2">
      <p class="text-gold-600 text-sm tracking-[0.25em] uppercase mb-4">About the Firm</p>
      <h2 class="text-4xl md:text-5xl font-serif text-navy-900 leading-tight">
        Senior attention.<br />
        <span class="italic text-gold-600">Without exception.</span>
      </h2>
      <span class="gold-divider"></span>
      <p class="text-navy-700 text-lg leading-relaxed mb-5">
        ALSA Law is a senior-counsel boutique with offices in Abu Dhabi and London. Founded by practitioners with decades of experience at the highest levels of the Bar and government, the firm was built on a simple promise: every client matter receives the partner-level judgment our founders spent their careers building.
      </p>
      <p class="text-navy-700 text-lg leading-relaxed mb-8">
        That commitment defines how we work — the relationships we build, the counsel we provide, and the long-term perspective we bring to every matter. Our clients trust us with their most consequential decisions, and we approach each one with the full weight of our experience and judgment.
      </p>
      <div class="grid grid-cols-2 gap-6 max-w-lg">
        <div class="border-l-2 border-gold-400 pl-4">
          <div class="font-serif text-2xl text-navy-900">60+ Years</div>
          <div class="text-sm text-navy-600 mt-1">Combined Experience</div>
        </div>
        <div class="border-l-2 border-gold-400 pl-4">
          <div class="font-serif text-2xl text-navy-900">40+</div>
          <div class="text-sm text-navy-600 mt-1">Government &amp; Institutional Entities Advised</div>
        </div>
        <div class="border-l-2 border-gold-400 pl-4">
          <div class="font-serif text-2xl text-navy-900">2 Offices</div>
          <div class="text-sm text-navy-600 mt-1">Abu Dhabi · London</div>
        </div>
      </div>

    </div>

  </div>
</section>
