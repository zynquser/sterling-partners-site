---
---
<section class="landing relative min-h-screen flex items-center justify-center overflow-hidden bg-navy-950 text-white">
  <!-- Layered atmospheric background -->
  <div class="absolute inset-0 -z-0">
    <!-- Base gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-900 to-navy-950"></div>

    <!-- Drifting bronze glows -->
    <div class="orb orb-1 absolute top-1/4 right-[15%] w-[55vmin] h-[55vmin] rounded-full bg-gold-400/10 blur-3xl"></div>
    <div class="orb orb-2 absolute bottom-1/4 left-[10%] w-[45vmin] h-[45vmin] rounded-full bg-gold-500/10 blur-3xl"></div>

    <!-- Decorative bronze arc, echoes the brand deck -->
    <svg class="hidden arc absolute top-0 right-0 w-[70vmin] h-[70vmin] opacity-40 pointer-events-none" viewBox="0 0 200 200" fill="none" preserveAspectRatio="xMaxYMin meet">
      <defs>
        <linearGradient id="bronzeStroke" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="rgba(186,145,109,0)"/>
          <stop offset="50%" stop-color="rgba(186,145,109,0.7)"/>
          <stop offset="100%" stop-color="rgba(186,145,109,0)"/>
        </linearGradient>
      </defs>
      <path d="M200,0 Q140,80 60,140 T-20,200" stroke="url(#bronzeStroke)" stroke-width="0.5" fill="none"/>
    </svg>

    <svg class="hidden arc absolute bottom-0 left-0 w-[60vmin] h-[60vmin] opacity-30 pointer-events-none" viewBox="0 0 200 200" fill="none" preserveAspectRatio="xMinYMax meet">
      <defs>
        <linearGradient id="bronzeStroke2" x1="100%" y1="100%" x2="0%" y2="0%">
          <stop offset="0%" stop-color="rgba(186,145,109,0)"/>
          <stop offset="50%" stop-color="rgba(186,145,109,0.6)"/>
          <stop offset="100%" stop-color="rgba(186,145,109,0)"/>
        </linearGradient>
      </defs>
      <path d="M0,200 Q60,120 140,60 T220,0" stroke="url(#bronzeStroke2)" stroke-width="0.5" fill="none"/>
    </svg>

    <!-- Subtle grid -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.025]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid-landing" width="80" height="80" patternUnits="userSpaceOnUse">
          <path d="M80 0H0V80" fill="none" stroke="white" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid-landing)" />
    </svg>
  </div>

  <!-- Centered brand stack -->
  <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
    <!-- Logo with glow + breathing -->
    <div class="logo-wrap relative inline-block">
      <span class="logo-halo absolute inset-0 rounded-full bg-gold-400/25 blur-3xl" aria-hidden="true"></span>
      <img
        src="/logo-mark.png"
        alt="ALSA Law"
        width="480"
        height="480"
        class="logo-mark relative w-32 md:w-40 lg:w-48 mx-auto select-none"
      />
    </div>

    <!-- Wordmark -->
    <h1 class="wordmark mt-10 md:mt-12 font-serif text-5xl md:text-7xl lg:text-[5.5rem] text-gold-400 tracking-[0.04em] leading-none">
      ALSA Law
    </h1>

    <!-- Gold divider -->
    <div class="divider mx-auto mt-7 h-px w-20 bg-gold-400/70"></div>

    <!-- Tagline -->
    <p class="tagline mt-6 font-serif italic text-lg md:text-2xl text-white/80 tracking-wide">
      Where Law Meets Leadership
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-cue absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 text-white/45 text-[10px] tracking-[0.4em] uppercase">
    <span>Scroll</span>
    <span class="scroll-line block w-px h-10 bg-gradient-to-b from-gold-400/70 to-transparent origin-top"></span>
  </div>
</section>

<style>
  /* === Entrance choreography === */
  .logo-wrap {
    opacity: 0;
    animation: enterLogo 1.6s cubic-bezier(0.2, 0.8, 0.2, 1) 0.2s forwards;
  }
  .wordmark {
    opacity: 0;
    transform: translateY(20px);
    animation: enterUp 1.1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.9s forwards;
  }
  .divider {
    transform: scaleX(0);
    transform-origin: center;
    animation: enterDivider 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) 1.4s forwards;
  }
  .tagline {
    opacity: 0;
    transform: translateY(16px);
    animation: enterUp 1.1s cubic-bezier(0.2, 0.8, 0.2, 1) 1.7s forwards;
  }
  .scroll-cue {
    opacity: 0;
    animation: enterFade 1.2s ease-out 2.2s forwards;
  }

  @keyframes enterLogo {
    0%   { opacity: 0; transform: scale(0.88); filter: blur(6px); }
    100% { opacity: 1; transform: scale(1);    filter: blur(0); }
  }
  @keyframes enterUp {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes enterDivider {
    to { transform: scaleX(1); }
  }
  @keyframes enterFade {
    to { opacity: 1; }
  }

  /* === Continuous ambient motion === */

  /* Logo gently breathes */
  .logo-mark {
    animation: breathe 6s ease-in-out 1.6s infinite;
  }
  @keyframes breathe {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.025); }
  }

  /* Halo behind logo pulses softly */
  .logo-halo {
    transform: scale(1.15);
    animation: glowPulse 5s ease-in-out 1s infinite;
  }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.45; transform: scale(1.15); }
    50%      { opacity: 0.85; transform: scale(1.35); }
  }

  /* Bronze orbs drift slowly */
  .orb-1 { animation: drift1 22s ease-in-out infinite; }
  .orb-2 { animation: drift2 26s ease-in-out infinite; }
  @keyframes drift1 {
    0%, 100% { transform: translate(0, 0); }
    50%      { transform: translate(45px, 35px); }
  }
  @keyframes drift2 {
    0%, 100% { transform: translate(0, 0); }
    50%      { transform: translate(-35px, -45px); }
  }

  /* Decorative arcs slowly fade in & out */
  .arc { animation: arcFlow 14s ease-in-out infinite; }
  @keyframes arcFlow {
    0%, 100% { opacity: 0.25; }
    50%      { opacity: 0.55; }
  }

  /* Scroll line pulse */
  .scroll-line { animation: linePulse 2.5s ease-in-out infinite; }
  @keyframes linePulse {
    0%, 100% { transform: scaleY(1);    opacity: 0.55; }
    50%      { transform: scaleY(1.4);  opacity: 1; }
  }

  /* Reduced-motion users get the static composition */
  @media (prefers-reduced-motion: reduce) {
    .logo-wrap, .wordmark, .divider, .tagline, .scroll-cue {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .logo-mark, .logo-halo, .orb-1, .orb-2, .arc, .scroll-line {
      animation: none;
    }
  }
</style>
