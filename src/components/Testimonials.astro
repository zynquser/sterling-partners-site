---
import { getCollection, render } from "astro:content";

const items = (await getCollection("testimonials")).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  items.map(async (entry) => {
    const { Content } = await render(entry);
    return { ...entry, Content };
  })
);
---
<section id="testimonials" class="py-24 md:py-32 bg-cream">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="max-w-3xl mb-16">
      <p class="text-gold-600 text-sm tracking-[0.25em] uppercase mb-4">In their words</p>
      <h2 class="text-4xl md:text-5xl font-serif text-navy-900 leading-tight">
        Trusted by those who can choose any counsel.
      </h2>
      <span class="gold-divider"></span>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {rendered.map((t) => (
        <figure class="bg-white border border-navy-100 p-8 lg:p-10 flex flex-col">
          <svg class="text-gold-400 mb-6" width="36" height="28" viewBox="0 0 36 28" fill="currentColor" aria-hidden="true">
            <path d="M0 28V16C0 7 5 1 14 0v6C9 7 6 11 6 16h8v12H0zm22 0V16C22 7 27 1 36 0v6c-5 1-8 5-8 10h8v12H22z"/>
          </svg>
          <blockquote class="font-serif text-xl text-navy-800 leading-snug flex-1 [&_p]:m-0">
            <t.Content />
          </blockquote>
          <figcaption class="mt-8 pt-6 border-t border-navy-100">
            <div class="font-medium text-navy-900">{t.data.author}</div>
            <div class="text-sm text-navy-600 mt-0.5">{t.data.role}</div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
