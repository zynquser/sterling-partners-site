---
const year = new Date().getFullYear();
---
<footer class="bg-navy-950 text-white/70 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 grid md:grid-cols-4 gap-10">
    <div class="md:col-span-2">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex items-center justify-center w-10 h-10 rounded-sm border border-gold-400/70 text-gold-300 font-serif text-xl">A</span>
        <span class="text-white font-serif text-xl">ALSA <span class="text-gold-300">Law</span></span>
      </div>
      <p class="max-w-md text-sm leading-relaxed">
        A boutique firm of senior counsel serving executives, families, and institutions on their most consequential legal matters. Established 2025, Abu Dhabi & London.
      </p>
    </div>

    <div>
      <div class="text-white text-sm tracking-widest uppercase mb-4">Offices</div>
      <ul class="space-y-2 text-sm">
        <li>Abu Dhabi</li>
        <li>London</li>
      </ul>
    </div>

    <div>
      <div class="text-white text-sm tracking-widest uppercase mb-4">Practice</div>
      <ul class="space-y-2 text-sm">
        <li><a href="#practice" class="hover:text-gold-300 transition-colors">Corporate &amp; Business</a></li>
        <li><a href="#practice" class="hover:text-gold-300 transition-colors">Litigation &amp; Disputes</a></li>
        <li><a href="#practice" class="hover:text-gold-300 transition-colors">Family &amp; Estate</a></li>
        <li><a href="#practice" class="hover:text-gold-300 transition-colors">Real Estate</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-6 flex flex-col md:flex-row gap-3 md:items-center md:justify-between text-xs text-white/50">
      <div>© {year} ALSA Law LLP. All rights reserved.</div>
      <div class="flex gap-6">
        <a href="#" class="hover:text-gold-300">Privacy</a>
        <a href="#" class="hover:text-gold-300">Legal Notices</a>
        <a href="#" class="hover:text-gold-300">Attorney Advertising</a>
      </div>
    </div>
  </div>
</footer>
