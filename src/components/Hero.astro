---
---
<section class="relative min-h-[92vh] flex items-center overflow-hidden bg-navy-900 text-white">
  <!-- Layered background -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-950 via-navy-800 to-navy-900"></div>
    <div class="absolute inset-0 opacity-[0.07]"
         style="background-image: radial-gradient(circle at 25% 30%, var(--color-gold-300) 0, transparent 35%), radial-gradient(circle at 80% 70%, var(--color-gold-400) 0, transparent 30%);">
    </div>
    <!-- subtle pattern -->
    <svg class="absolute inset-0 w-full h-full opacity-[0.04]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M60 0H0V60" fill="none" stroke="white" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-10 items-center pt-32 pb-24">
    <div class="lg:col-span-7 fade-in">
      <p class="text-gold-300 text-sm tracking-[0.25em] uppercase mb-6">Abu Dhabi · London</p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif leading-[1.05] text-white">
        Counsel that <span class="italic text-gold-300">stands</span><br />
        the test of time.
      </h1>
      <span class="gold-divider"></span>
      <p class="text-lg md:text-xl text-white/80 max-w-xl leading-relaxed">
        ALSA Law brings together senior counsel with decades of practice at the highest levels of the Bar to guide executives, families, and institutions through their most consequential legal matters — with the discretion, judgment, and senior attention every client deserves.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a href="#contact" class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-gold-400 text-navy-900 font-medium hover:bg-gold-300 transition-colors">
          Request a Confidential Consultation
          <span aria-hidden="true">→</span>
        </a>
        <a href="#practice" class="inline-flex items-center justify-center gap-2 px-7 py-4 border border-white/30 text-white hover:border-gold-300 hover:text-gold-300 transition-colors">
          Explore Practice Areas
        </a>
      </div>
      <div class="hidden mt-12 grid grid-cols-3 gap-6 max-w-lg border-t border-white/10 pt-8">
        <div>
          <div class="font-serif text-3xl text-gold-300">40+</div>
          <div class="text-xs uppercase tracking-wider text-white/60 mt-1">Years Senior Counsel</div>
        </div>
        <div class="hidden">
          <div class="font-serif text-3xl text-gold-300">120+</div>
          <div class="text-xs uppercase tracking-wider text-white/60 mt-1">Attorneys</div>
        </div>
        <div class="hidden">
          <div class="font-serif text-3xl text-gold-300">$8B+</div>
          <div class="text-xs uppercase tracking-wider text-white/60 mt-1">Transactions Counseled</div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-5 hidden lg:block">
      <div class="relative">
        <div class="absolute -top-6 -left-6 w-32 h-32 border-2 border-gold-400/40"></div>
        <div class="absolute -bottom-6 -right-6 w-32 h-32 border-2 border-gold-400/40"></div>
        <div class="relative aspect-[4/5] bg-gradient-to-b from-navy-700 to-navy-950 border border-gold-400/30 p-10 flex flex-col">
          <div class="text-gold-300 text-xs tracking-[0.3em] uppercase mb-8">Our Standard</div>
          <div class="flex-1 flex flex-col justify-between gap-6">
            <div>
              <div class="font-serif text-2xl text-gold-300 mb-2">Law</div>
              <p class="text-sm text-white/75 leading-relaxed">Deep expertise across UAE and international frameworks.</p>
            </div>
            <div class="border-t border-white/10 pt-6">
              <div class="font-serif text-2xl text-gold-300 mb-2">Leadership</div>
              <p class="text-sm text-white/75 leading-relaxed">Partner-led decision support at the highest level.</p>
            </div>
            <div class="border-t border-white/10 pt-6">
              <div class="font-serif text-2xl text-gold-300 mb-2">Longevity</div>
              <p class="text-sm text-white/75 leading-relaxed">Solutions built for resilience and lasting value.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white/5 to-transparent pointer-events-none"></div>
</section>
