---
import { getCollection, render } from "astro:content";

const areas = (await getCollection("practiceAreas")).sort(
  (a, b) => a.data.order - b.data.order
);

const rendered = await Promise.all(
  areas.map(async (entry) => {
    const { Content } = await render(entry);
    return { ...entry, Content };
  })
);

const icons: Record<string, string> = {
  scales: `<path d="M12 3v18M5 8l-3 5a3 3 0 006 0l-3-5zm14 0l-3 5a3 3 0 006 0l-3-5zM5 8h14M8 21h8" />`,
  gavel: `<path d="M14 4l6 6-3 3-6-6 3-3zM10 8l-7 7 3 3 7-7M14 17l4 4M3 21h12" />`,
  tree: `<path d="M12 22V14M8 14h8l-2-3h1l-3-4h1l-3-4-3 4h1l-3 4h1l-2 3z" />`,
  building: `<path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M15 9h.01M9 13h.01M15 13h.01M9 17h.01M15 17h.01" />`,
  shield: `<path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3zM9 12l2 2 4-4" />`,
};
---
<section id="practice" class="relative py-24 md:py-32 bg-cream">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="max-w-2xl">
      <p class="text-gold-600 text-sm tracking-[0.25em] uppercase mb-4">Practice Areas</p>
      <h2 class="text-4xl md:text-5xl font-serif text-navy-900 leading-tight">
        Five practices, one standard of care.
      </h2>
      <span class="gold-divider"></span>
      <p class="text-navy-700 text-lg leading-relaxed">
        Our practice is deliberately concentrated. We accept matters where senior judgment makes a measurable difference — and decline those where it does not.
      </p>
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-6 lg:gap-8">
      {rendered.map((area) => (
        <article class="group relative bg-white border border-navy-100 hover:border-gold-400 transition-colors p-8 lg:p-10 flex flex-col">
          <div class="flex items-start justify-between gap-4 mb-6">
            <div class="w-14 h-14 flex items-center justify-center bg-navy-900 text-gold-300 group-hover:bg-gold-400 group-hover:text-navy-900 transition-colors">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[area.data.icon] ?? icons.scales}></svg>
            </div>
            <span class="text-gold-500 text-xs tracking-[0.25em] uppercase pt-2">0{area.data.order}</span>
          </div>
          <h3 class="font-serif text-2xl text-navy-900 mb-3">{area.data.title}</h3>
          <p class="text-navy-700 leading-relaxed mb-6">{area.data.summary}</p>
          <div class="prose prose-sm prose-navy max-w-none text-navy-600 mb-6 [&_strong]:text-navy-900 [&_strong]:font-semibold [&_ul]:list-none [&_ul]:pl-0 [&_li]:relative [&_li]:pl-5 [&_li]:py-1 [&_li]:before:content-[''] [&_li]:before:absolute [&_li]:before:left-0 [&_li]:before:top-[0.7em] [&_li]:before:w-2 [&_li]:before:h-px [&_li]:before:bg-gold-400">
            <area.Content />
          </div>
          <a href="#contact" class="mt-auto inline-flex items-center gap-2 text-navy-900 font-medium border-b border-navy-200 hover:border-gold-500 hover:text-gold-700 self-start pt-2 pb-1 transition-colors">
            Discuss your matter
            <span aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
