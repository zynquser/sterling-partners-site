---
import { getCollection } from "astro:content";

const areas = (await getCollection("practiceAreas")).sort(
  (a, b) => a.data.order - b.data.order
);

const icons: Record<string, string> = {
  scales: `<path d="M12 3v18M5 8l-3 5a3 3 0 006 0l-3-5zm14 0l-3 5a3 3 0 006 0l-3-5zM5 8h14M8 21h8" />`,
  gavel: `<path d="M14 4l6 6-3 3-6-6 3-3zM10 8l-7 7 3 3 7-7M14 17l4 4M3 21h12" />`,
  tree: `<path d="M12 22V14M8 14h8l-2-3h1l-3-4h1l-3-4-3 4h1l-3 4h1l-2 3z" />`,
  building: `<path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M15 9h.01M9 13h.01M15 13h.01M9 17h.01M15 17h.01" />`,
  shield: `<path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3zM9 12l2 2 4-4" />`,
  seal: `<path d="M14 3H6a2 2 0 00-2 2v14a2 2 0 002 2h12a2 2 0 002-2V9l-6-6zM14 3v6h6M9 14a3 3 0 106 0 3 3 0 00-6 0zM12 17v3" />`,
  trending: `<path d="M22 7l-8.5 8.5-5-5L2 17M16 7h6v6" />`,
};

// Punchy one-liners — no prose
const shortDesc: Record<string, string> = {
  "Transactional & M&A Advisory":           "Full-cycle M&A and commercial advisory, from strategic structuring to closing.",
  "Dispute Resolution & Arbitration":        "High-stakes disputes across UAE courts, Free Zones, and international arbitration.",
  "Private Client & Family Office Advisory": "Succession, governance, and legacy counsel for families and family offices.",
  "Real Estate & Investment Structuring":    "Acquisitions, disposals, and developer advisory in Abu Dhabi's property market.",
  "Regulatory & Compliance":                 "Translating complex regulatory regimes into clear, workable internal governance.",
  "Notary Services":                         "Precise, discreet notarial services for corporate and personal instruments.",
  "Venture & Growth Advisory":               "Legal infrastructure for founders — from first incorporation through fundraising rounds to exit.",
};

const serviceTags: Record<string, string[]> = {
  "Transactional & M&A Advisory":           ["M&A", "Commercial", "Incorporation"],
  "Dispute Resolution & Arbitration":        ["Litigation", "Arbitration", "ADR"],
  "Private Client & Family Office Advisory": ["Succession", "Family Offices", "Trusts"],
  "Real Estate & Investment Structuring":    ["Real Estate", "Construction", "Infrastructure"],
  "Regulatory & Compliance":                 ["AML", "Governance", "Employment"],
  "Notary Services":                         ["Corporate Docs", "Attestation", "Confidential Matters"],
  "Venture & Growth Advisory":               ["Fundraising", "Founder Advisory", "Exits & Acquisitions"],
};
---

<section id="practice" class="relative bg-cream text-navy-900 overflow-hidden">

  <!-- ░░ Section header ░░ -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 pt-24 pb-16 lg:pb-20">
    <p class="text-gold-600 text-sm tracking-[0.25em] uppercase mb-4">Practice Areas</p>
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-serif text-navy-900 leading-[1.1]">
      Seven practices.<br />
      <span class="italic text-gold-500">One standard of care.</span>
    </h2>
    <span class="gold-divider"></span>
    <p class="text-navy-600 text-base max-w-sm leading-relaxed">
      Deliberately concentrated — we take on matters where senior judgment makes the difference.
    </p>
  </div>

  <!-- ░░ Alternating editorial rows ░░ -->
  <div class="relative z-10">
    {areas.map((area, i) => {
      const isRight = i % 2 === 1;
      const desc = shortDesc[area.data.title] ?? area.data.summary;
      const tags = serviceTags[area.data.title] ?? [];
      return (
        <div class="border-t border-navy-100 group hover:bg-white/60 transition-colors duration-300">
          <div class={`max-w-7xl mx-auto px-6 lg:px-10 py-10 lg:py-14 flex gap-6 lg:gap-10 items-center flex-col md:flex-row ${isRight ? 'md:flex-row-reverse' : 'md:flex-row'}`}>

            {/* ── Giant decorative number, outer edge ── */}
            <div class="hidden xl:block flex-shrink-0 w-24 text-center">
              <span class="font-serif text-[5.5rem] leading-none select-none text-navy-900/[0.06] group-hover:text-navy-900/[0.1] transition-colors tabular-nums">
                {String(area.data.order).padStart(2, "0")}
              </span>
            </div>

            {/* ── Icon + Title ── */}
            <div class={`flex-shrink-0 w-full md:w-56 lg:w-64 ${isRight ? 'md:text-right' : 'md:text-left'}`}>
              <div class={`w-10 h-10 flex items-center justify-center border border-gold-500/40 text-gold-500 mb-5 group-hover:border-gold-500 group-hover:bg-gold-500/10 transition-colors ${isRight ? 'md:ml-auto' : ''}`}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icons[area.data.icon] ?? icons.scales}></svg>
              </div>
              <h3 class="font-serif text-[1.55rem] lg:text-[1.75rem] text-navy-900 leading-snug">{area.data.title}</h3>
              <p class="hidden md:block text-[10px] tracking-[0.22em] uppercase text-gold-500/50 mt-2">
                {String(area.data.order).padStart(2, "0")} / 07
              </p>
            </div>

            {/* ── Vertical rule ── */}
            <div class="hidden lg:block flex-shrink-0 w-px self-stretch min-h-[4rem] bg-navy-200"></div>

            {/* ── Description + service tags ── */}
            <div class="flex-1 min-w-0">
              <p class="text-navy-700 text-base lg:text-[1.05rem] leading-relaxed mb-5">{desc}</p>
              <div class="flex flex-wrap gap-2">
                {tags.map(tag => (
                  <span class="text-[10px] tracking-[0.18em] uppercase border border-gold-500/30 text-gold-600/70 px-3 py-1.5 group-hover:border-gold-500/60 group-hover:text-gold-600 transition-colors">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            {/* ── CTA ── */}
            <div class="flex-shrink-0 self-end md:self-center pb-1 md:pb-0">
              <a
                href="#contact"
                class="inline-flex items-center gap-2 text-[11px] tracking-[0.18em] uppercase font-medium text-navy-700 hover:text-gold-600 border-b border-navy-300 hover:border-gold-500 pb-1 transition-colors whitespace-nowrap"
              >
                Discuss
                <span aria-hidden="true" class="text-sm">→</span>
              </a>
            </div>

          </div>
        </div>
      );
    })}
    <div class="border-t border-navy-100"></div>
  </div>

  <div class="relative z-10 pb-24 lg:pb-32"></div>
</section>
