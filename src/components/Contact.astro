---
---
<section id="contact" class="py-24 md:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-12 gap-12 lg:gap-16">
    <div class="lg:col-span-5">
      <p class="text-gold-600 text-sm tracking-[0.25em] uppercase mb-4">Schedule a Consultation</p>
      <h2 class="text-4xl md:text-5xl font-serif text-navy-900 leading-tight">
        A confidential first conversation.
      </h2>
      <span class="gold-divider"></span>
      <p class="text-navy-700 text-lg leading-relaxed mb-10">
        Tell us briefly about your matter. A member of our team will respond within one business day.
      </p>

      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-navy-900 text-gold-300 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h18v14H3zM3 5l9 7 9-7"/></svg>
          </div>
          <div>
            <div class="text-xs tracking-widest uppercase text-navy-500 mb-1">Email</div>
            <a href="mailto:info@alsalaw.com" class="text-navy-900 hover:text-gold-700">info@alsalaw.com</a>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-navy-900 text-gold-300 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <div class="text-xs tracking-widest uppercase text-navy-500 mb-1">Telephone</div>
            <a href="tel:+97125550100" class="text-navy-900 hover:text-gold-700">+971 2 555 0100</a>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-navy-900 text-gold-300 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="text-xs tracking-widest uppercase text-navy-500 mb-1">Abu Dhabi</div>
            <div class="text-navy-900">202, Radiant Heights, Radiant Square<br />Al Reem Island, Abu Dhabi, United Arab Emirates</div>
          </div>
        </div>
      </div>
    </div>

    <div class="hidden lg:col-span-7">
      <form
        name="consultation"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="bg-cream border border-navy-100 p-8 lg:p-10"
      >
        <input type="hidden" name="form-name" value="consultation" />
        <p class="hidden">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="grid sm:grid-cols-2 gap-5 mb-5">
          <label class="block">
            <span class="text-xs tracking-widest uppercase text-navy-700">First Name</span>
            <input required name="firstName" type="text" class="mt-2 w-full border-b border-navy-300 bg-transparent py-2 focus:border-gold-500 focus:outline-none transition-colors" />
          </label>
          <label class="block">
            <span class="text-xs tracking-widest uppercase text-navy-700">Last Name</span>
            <input required name="lastName" type="text" class="mt-2 w-full border-b border-navy-300 bg-transparent py-2 focus:border-gold-500 focus:outline-none transition-colors" />
          </label>
        </div>

        <div class="grid sm:grid-cols-2 gap-5 mb-5">
          <label class="block">
            <span class="text-xs tracking-widest uppercase text-navy-700">Email</span>
            <input required name="email" type="email" class="mt-2 w-full border-b border-navy-300 bg-transparent py-2 focus:border-gold-500 focus:outline-none transition-colors" />
          </label>
          <label class="block">
            <span class="text-xs tracking-widest uppercase text-navy-700">Telephone</span>
            <input name="phone" type="tel" class="mt-2 w-full border-b border-navy-300 bg-transparent py-2 focus:border-gold-500 focus:outline-none transition-colors" />
          </label>
        </div>

        <label class="block mb-5">
          <span class="text-xs tracking-widest uppercase text-navy-700">Practice Area</span>
          <select name="practiceArea" class="mt-2 w-full border-b border-navy-300 bg-transparent py-2 focus:border-gold-500 focus:outline-none transition-colors">
            <option>Transactional &amp; M&amp;A Advisory</option>
            <option>Dispute Resolution &amp; Arbitration</option>
            <option>Private Client &amp; Family Office Advisory</option>
            <option>Real Estate &amp; Investment Structuring</option>
            <option>Other / Not sure</option>
          </select>
        </label>

        <label class="block mb-8">
          <span class="text-xs tracking-widest uppercase text-navy-700">Briefly, the matter</span>
          <textarea required name="message" rows="5" class="mt-2 w-full border-b border-navy-300 bg-transparent py-2 focus:border-gold-500 focus:outline-none transition-colors resize-none"></textarea>
        </label>

        <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-navy-900 text-white hover:bg-gold-400 hover:text-navy-900 transition-colors">
          Send Confidential Inquiry
          <span aria-hidden="true">→</span>
        </button>

        <p class="text-xs text-navy-500 mt-6 leading-relaxed">
          Submitting this form does not create an attorney–client relationship. Please do not include confidential information in your initial inquiry.
        </p>
      </form>
    </div>
  </div>
</section>
