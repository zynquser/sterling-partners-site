---
---
<section id="contact" class="relative overflow-hidden text-white">

  <!-- ░░ Background: dark wood-panelled conference room ░░ -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <img
      src="https://images.unsplash.com/photo-1568992687947-868a62a9f521?auto=format&fit=crop&w=1920&q=80"
      alt=""
      class="w-full h-full object-cover object-center"
      loading="lazy"
    />
    <!-- Warm dark overlay — preserves amber/mahogany tones of the room -->
    <div class="absolute inset-0 bg-navy-950/78"></div>
    <!-- Subtle warm radial glow from left (fireplace/lamp effect) -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 60% 70% at 15% 60%, rgba(185,145,109,0.12) 0%, transparent 65%);"></div>
  </div>

  <!-- ░░ Content ░░ -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 py-24 md:py-32 grid lg:grid-cols-12 gap-12 lg:gap-16">

    <!-- Left: header + contact details -->
    <div class="lg:col-span-5">
      <p class="text-gold-400 text-sm tracking-[0.25em] uppercase mb-4">Schedule a Consultation</p>
      <h2 class="text-4xl md:text-5xl font-serif text-white leading-tight">
        A discreet<br />
        <span class="italic text-gold-300">first conversation.</span>
      </h2>
      <span class="gold-divider"></span>
      <p class="text-white/65 text-lg leading-relaxed mb-10">
        Tell us briefly about your matter. A member of our team will respond within one business day.
      </p>

      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 border border-gold-400/40 text-gold-300 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h18v14H3zM3 5l9 7 9-7"/></svg>
          </div>
          <div>
            <div class="text-[10px] tracking-[0.25em] uppercase text-gold-400/60 mb-1">Email</div>
            <a href="mailto:info@alsalaw.com" class="text-white/85 hover:text-gold-300 transition-colors">info@alsalaw.com</a>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 border border-gold-400/40 text-gold-300 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <div class="text-[10px] tracking-[0.25em] uppercase text-gold-400/60 mb-1">Telephone</div>
            <a href="tel:+97150750356" class="text-white/85 hover:text-gold-300 transition-colors">+971 50 750 0356</a>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 border border-gold-400/40 text-gold-300 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="text-[10px] tracking-[0.25em] uppercase text-gold-400/60 mb-1">Abu Dhabi</div>
            <div class="text-white/75 leading-relaxed">202, Radiant Heights, Radiant Square<br />Al Reem Island, Abu Dhabi, UAE</div>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 border border-gold-400/40 text-gold-300 flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="text-[10px] tracking-[0.25em] uppercase text-gold-400/60 mb-1">London</div>
            <div class="text-white/75 leading-relaxed">London, United Kingdom</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: consultation form -->
    <div class="hidden lg:col-span-7">
      <form
        name="consultation"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="border border-white/10 bg-navy-950/50 backdrop-blur-sm p-8 lg:p-10"
      >
        <input type="hidden" name="form-name" value="consultation" />
        <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div class="grid sm:grid-cols-2 gap-5 mb-5">
          <label class="block">
            <span class="text-[10px] tracking-[0.25em] uppercase text-gold-400/70">First Name</span>
            <input required name="firstName" type="text" class="mt-2 w-full border-b border-white/20 bg-transparent py-2 text-white placeholder-white/30 focus:border-gold-400 focus:outline-none transition-colors" />
          </label>
          <label class="block">
            <span class="text-[10px] tracking-[0.25em] uppercase text-gold-400/70">Last Name</span>
            <input required name="lastName" type="text" class="mt-2 w-full border-b border-white/20 bg-transparent py-2 text-white placeholder-white/30 focus:border-gold-400 focus:outline-none transition-colors" />
          </label>
        </div>

        <div class="grid sm:grid-cols-2 gap-5 mb-5">
          <label class="block">
            <span class="text-[10px] tracking-[0.25em] uppercase text-gold-400/70">Email</span>
            <input required name="email" type="email" class="mt-2 w-full border-b border-white/20 bg-transparent py-2 text-white placeholder-white/30 focus:border-gold-400 focus:outline-none transition-colors" />
          </label>
          <label class="block">
            <span class="text-[10px] tracking-[0.25em] uppercase text-gold-400/70">Telephone</span>
            <input name="phone" type="tel" class="mt-2 w-full border-b border-white/20 bg-transparent py-2 text-white placeholder-white/30 focus:border-gold-400 focus:outline-none transition-colors" />
          </label>
        </div>

        <label class="block mb-5">
          <span class="text-[10px] tracking-[0.25em] uppercase text-gold-400/70">Practice Area</span>
          <select name="practiceArea" class="mt-2 w-full border-b border-white/20 bg-transparent py-2 text-white focus:border-gold-400 focus:outline-none transition-colors">
            <option class="bg-navy-900">Transactional &amp; M&amp;A Advisory</option>
            <option class="bg-navy-900">Dispute Resolution &amp; Arbitration</option>
            <option class="bg-navy-900">Private Client &amp; Family Office Advisory</option>
            <option class="bg-navy-900">Real Estate &amp; Investment Structuring</option>
            <option class="bg-navy-900">Venture &amp; Growth Advisory</option>
            <option class="bg-navy-900">Regulatory &amp; Compliance</option>
            <option class="bg-navy-900">Notary Services</option>
            <option class="bg-navy-900">Other / Not sure</option>
          </select>
        </label>

        <label class="block mb-8">
          <span class="text-[10px] tracking-[0.25em] uppercase text-gold-400/70">Briefly, the matter</span>
          <textarea required name="message" rows="4" class="mt-2 w-full border-b border-white/20 bg-transparent py-2 text-white placeholder-white/30 focus:border-gold-400 focus:outline-none transition-colors resize-none"></textarea>
        </label>

        <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-gold-400 text-navy-900 font-medium hover:bg-gold-300 transition-colors">
          Send Inquiry
          <span aria-hidden="true">→</span>
        </button>

        <p class="text-xs text-white/35 mt-6 leading-relaxed">
          Submitting this form does not create an attorney–client relationship.
        </p>
      </form>
    </div>

  </div>
</section>
